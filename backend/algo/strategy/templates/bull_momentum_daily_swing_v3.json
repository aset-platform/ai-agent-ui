{
  "id": "00000000-0000-0000-0000-000000000022",
  "name": "BULL — Daily Momentum + Sector + Volume (CNC Swing v3 / loosened)",
  "universe": {
    "type": "scope",
    "scope": "discovery",
    "filter": {
      "ticker_type": ["stock"],
      "market": "india"
    }
  },
  "schedule": {
    "type": "bar_close",
    "interval": "1d",
    "time": "15:25 IST"
  },
  "rebalance": {
    "type": "daily",
    "max_positions": 5
  },
  "product": "CNC",
  "root": {
    "type": "if",
    "cond": {
      "type": "and",
      "operands": [
        {
          "type": "compare",
          "left": {"feature": "regime_label"},
          "op": "==",
          "right": {"literal": "BULL"}
        },
        {
          "type": "compare",
          "left": {"feature": "rs_vs_sector_3m"},
          "op": ">",
          "right": {"literal": 0.0}
        },
        {
          "type": "compare",
          "left": {"feature": "volume_x_avg_20"},
          "op": ">=",
          "right": {"literal": 1.5}
        },
        {
          "type": "compare",
          "left": {"feature": "distance_from_sma200"},
          "op": ">",
          "right": {"literal": 0.0}
        },
        {
          "type": "compare",
          "left": {"feature": "mom_3_1"},
          "op": ">",
          "right": {"literal": 0.0}
        }
      ]
    },
    "then": {
      "type": "set_target_weight",
      "weight": 0.20
    },
    "else": {
      "type": "exit",
      "scope": "this_symbol"
    }
  },
  "risk": {
    "per_trade": {
      "stop_loss_pct": 4.0,
      "max_qty": 1000
    },
    "portfolio": {
      "max_exposure_pct": 100.0,
      "max_concentration_pct": 25.0
    },
    "daily": {
      "max_loss_pct": 5.0,
      "max_open_positions": 5
    }
  }
}
