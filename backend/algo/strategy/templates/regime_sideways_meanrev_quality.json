{
  "id": "00000000-0000-0000-0000-000000000011",
  "name": "SIDEWAYS — Mean Reversion + Quality",
  "universe": {
    "type": "scope",
    "scope": "discovery",
    "filter": {
      "ticker_type": ["stock"],
      "market": "india"
    }
  },
  "schedule": {
    "type": "bar_close",
    "interval": "1d",
    "time": "15:25 IST"
  },
  "rebalance": {
    "type": "daily",
    "max_positions": 8
  },
  "root": {
    "type": "and",
    "operands": [
      {
        "type": "compare",
        "left": {"feature": "regime_label"},
        "op": "==",
        "right": {"literal": "SIDEWAYS"}
      },
      {
        "type": "compare",
        "left": {"feature": "f_score"},
        "op": ">=",
        "right": {"literal": 7}
      },
      {
        "type": "compare",
        "left": {"feature": "realized_vol_60d"},
        "op": "<",
        "right": {"literal": 0.30}
      },
      {
        "type": "between",
        "value": {"feature": "rsi"},
        "low": {"literal": 30},
        "high": {"literal": 50}
      },
      {
        "type": "between",
        "value": {"feature": "distance_from_sma200"},
        "low": {"literal": -0.05},
        "high": {"literal": 0.10}
      }
    ]
  },
  "risk": {
    "per_trade": {
      "stop_loss_pct": 5.0,
      "max_qty": 800
    },
    "portfolio": {
      "max_exposure_pct": 60.0,
      "max_concentration_pct": 10.0
    },
    "daily": {
      "max_loss_pct": 3.0,
      "max_open_positions": 8
    }
  }
}
