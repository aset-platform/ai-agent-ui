# ── AI Agent UI — Environment Variables ──────────────
# Copy to .env and fill in your values.
# Docker Compose reads this file automatically.

# ── PostgreSQL ───────────────────────────────────────
PG_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://app:changeme@localhost:5432/aiagent

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LLM Providers ───────────────────────────────────
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# ── Round-Robin Model Pools ────────────────────────
# Spreads load across Groq models to avoid TPD limits.
# Set ROUND_ROBIN_ENABLED=false for legacy sequential.
# ROUND_ROBIN_ENABLED=true
# TOOL_POOL_PRIMARY=llama-3.3-70b-versatile,qwen/qwen3-32b
# TOOL_POOL_SECONDARY=openai/gpt-oss-120b,openai/gpt-oss-20b
# TOOL_POOL_TERTIARY=meta-llama/llama-4-scout-17b-16e-instruct
# SYNTHESIS_POOL_PRIMARY=openai/gpt-oss-120b,openai/gpt-oss-20b,qwen/qwen3-32b
# SYNTHESIS_POOL_SECONDARY=meta-llama/llama-4-scout-17b-16e-instruct

# ── Search ──────────────────────────────────────────
SERPAPI_API_KEY=

# ── Auth / JWT ──────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── BYO provider key encryption (Fernet) ────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required when any user configures their own Groq / Anthropic key.
BYO_SECRET_KEY=

# ── OAuth (leave empty to disable) ──────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
OAUTH_REDIRECT_URI=http://localhost:3000/auth/oauth/callback

# ── Payment Gateways (test mode) ───────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Create plans in Razorpay Dashboard → Subscriptions → Plans
RAZORPAY_PLAN_PRO=
RAZORPAY_PLAN_PREMIUM=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Create prices in Stripe Dashboard → Products → Pricing
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=

# ── Admin (seed script) ────────────────────────────
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FULL_NAME="Admin User"

# ── Agent / Pipeline ───────────────────────────────
AGENT_TIMEOUT_SECONDS=900
ENSEMBLE_ENABLED=true
LOG_LEVEL=INFO
LOG_TO_FILE=True

# ── Observability (LangSmith) ──────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ai-agent-ui
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=

# ── Observability (Langfuse) ───────────────────────
LANGFUSE_ENABLED=false
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Ollama (local LLM — host-native, not in Docker)─
# In Docker: use http://host.docker.internal:11434
# On host:   use http://localhost:11434
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434

# ── Frontend ────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=http://localhost:8181
NEXT_PUBLIC_DOCS_URL=http://localhost:8000

# ── Environment ─────────────────────────────────────
AI_AGENT_UI_ENV=dev
