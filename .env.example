# ── AI Agent UI — Environment Variables ──────────────
# Copy to .env and fill in your values.
# Docker Compose reads this file automatically.

# ── PostgreSQL ───────────────────────────────────────
PG_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://app:changeme@localhost:5432/aiagent

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LLM Providers ───────────────────────────────────
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# ── Search ──────────────────────────────────────────
SERPAPI_API_KEY=

# ── Auth / JWT ──────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# ── OAuth (leave empty to disable) ──────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── Payment Gateways (test mode) ───────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Create plans in Razorpay Dashboard → Subscriptions → Plans
RAZORPAY_PLAN_PRO=
RAZORPAY_PLAN_PREMIUM=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Create prices in Stripe Dashboard → Products → Pricing
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=

# ── Observability ───────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGSMITH_API_KEY=

# ── Ollama (local LLM — host-native, not in Docker)─
# In Docker: use http://host.docker.internal:11434
# On host:   use http://localhost:11434
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434

# ── Frontend ────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=http://localhost:8181
NEXT_PUBLIC_DOCS_URL=http://localhost:8000

# ── Environment ─────────────────────────────────────
AI_AGENT_UI_ENV=dev
