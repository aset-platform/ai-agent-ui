#!/usr/bin/env bash
# hooks/pre-push
#
# Pre-push quality gate for pushes to main.
#
# Checks (in order):
#   1. No bare print() calls in backend Python files   [HARD BLOCK — exit 1]
#   2. Module-level docstring on non-__init__.py files [WARNING only — exit 0]
#   3. mkdocs build passes                             [HARD BLOCK — exit 1]
#
# Install (one-time):
#   cp hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
#
# Test without pushing:
#   printf 'refs/heads/main 0000000000000000000000000000000000000000 refs/heads/main 0000000000000000000000000000000000000000\n' | bash hooks/pre-push
#
# Only enforces when the push target includes refs/heads/main.
# On any other branch, exits 0 immediately.

set -uo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
BACKEND_DIR="$PROJECT_ROOT/backend"
PYTHON="$PROJECT_ROOT/backend/demoenv/bin/python"
ACTIVATE="$PROJECT_ROOT/backend/demoenv/bin/activate"

# ── Branch guard ─────────────────────────────────────────────────────────────
# git passes push targets on stdin: <local_ref> <local_oid> <remote_ref> <remote_oid>
PUSHING_TO_MAIN=0
while read -r _local_ref _local_oid remote_ref _remote_oid; do
    if [[ "$remote_ref" == "refs/heads/main" ]]; then
        PUSHING_TO_MAIN=1
        break
    fi
done

if [[ "$PUSHING_TO_MAIN" -eq 0 ]]; then
    echo "[pre-push] Not targeting main — skipping quality checks."
    exit 0
fi

echo ""
echo "╔══════════════════════════════════════════════════════════════════╗"
echo "║           PRE-PUSH QUALITY GATE  (target: main)                 ║"
echo "╚══════════════════════════════════════════════════════════════════╝"
echo ""

ERRORS=0

# ── Check 1: No bare print() calls ───────────────────────────────────────────
echo "── [1/3] Checking for bare print() calls in backend Python files..."

PRINT_EXIT=0
PRINT_OUTPUT="$("$PYTHON" - "$BACKEND_DIR" 2>&1 <<'PYEOF'
import ast, os, sys

backend_dir = sys.argv[1]
violations = []

for dirpath, dirnames, filenames in os.walk(backend_dir):
    dirnames[:] = [
        d for d in dirnames
        if d not in ("demoenv", "__pycache__") and not d.endswith("env")
    ]
    for filename in filenames:
        if not filename.endswith(".py"):
            continue
        filepath = os.path.join(dirpath, filename)
        try:
            source = open(filepath, encoding="utf-8").read()
            tree = ast.parse(source, filename=filepath)
        except (SyntaxError, UnicodeDecodeError) as e:
            print(f"  [ERROR] Cannot parse {filepath}: {e}", file=sys.stderr)
            continue
        for node in ast.walk(tree):
            if (
                isinstance(node, ast.Call)
                and isinstance(node.func, ast.Name)
                and node.func.id == "print"
            ):
                rel = os.path.relpath(filepath, backend_dir)
                violations.append((rel, node.lineno))

for rel, lineno in sorted(violations):
    print(f"  [FAIL] backend/{rel}:{lineno}  — bare print() (use logging instead)")

sys.exit(len(violations))
PYEOF
)" || PRINT_EXIT=$?

if [[ $PRINT_EXIT -ne 0 ]]; then
    echo "$PRINT_OUTPUT"
    echo ""
    echo "  Fix: replace print() with the module logger."
    echo "       logger = logging.getLogger(__name__)"
    echo "       logger.debug(\"...\")  /  logger.info(\"...\")  etc."
    ERRORS=$((ERRORS + 1))
else
    echo "  [OK] No bare print() calls found."
fi
echo ""

# ── Check 2: Module-level docstrings (WARNING only) ───────────────────────────
echo "── [2/3] Checking module-level docstrings on backend Python files..."

DOC_EXIT=0
DOC_OUTPUT="$("$PYTHON" - "$BACKEND_DIR" 2>&1 <<'PYEOF'
import ast, os, sys

backend_dir = sys.argv[1]
warnings = []

for dirpath, dirnames, filenames in os.walk(backend_dir):
    dirnames[:] = [
        d for d in dirnames
        if d not in ("demoenv", "__pycache__") and not d.endswith("env")
    ]
    for filename in filenames:
        if not filename.endswith(".py") or filename == "__init__.py":
            continue
        filepath = os.path.join(dirpath, filename)
        try:
            source = open(filepath, encoding="utf-8").read()
            tree = ast.parse(source, filename=filepath)
        except (SyntaxError, UnicodeDecodeError) as e:
            print(f"  [ERROR] Cannot parse {filepath}: {e}", file=sys.stderr)
            continue
        has_doc = (
            tree.body
            and isinstance(tree.body[0], ast.Expr)
            and isinstance(tree.body[0].value, ast.Constant)
            and isinstance(tree.body[0].value.value, str)
        )
        if not has_doc:
            rel = os.path.relpath(filepath, backend_dir)
            warnings.append(rel)

for rel in sorted(warnings):
    print(f"  [WARN] backend/{rel}  — missing module-level docstring (add for MkDocs)")

sys.exit(0)  # warnings only, never block
PYEOF
)" || DOC_EXIT=$?

if [[ -n "$DOC_OUTPUT" ]]; then
    echo "$DOC_OUTPUT"
else
    echo "  [OK] All non-__init__.py files have module-level docstrings."
fi
echo ""

# ── Check 3: MkDocs build ─────────────────────────────────────────────────────
echo "── [3/3] Running mkdocs build..."

# shellcheck source=/dev/null
source "$ACTIVATE"
MKDOCS_TMPDIR="$(mktemp -d)"

MKDOCS_EXIT=0
MKDOCS_OUTPUT="$(mkdocs build \
    --config-file "$PROJECT_ROOT/mkdocs.yml" \
    --site-dir "$MKDOCS_TMPDIR" \
    2>&1)" || MKDOCS_EXIT=$?

rm -rf "$MKDOCS_TMPDIR"

if [[ $MKDOCS_EXIT -ne 0 ]]; then
    echo "$MKDOCS_OUTPUT"
    echo ""
    echo "  Fix: source backend/demoenv/bin/activate && mkdocs serve"
    ERRORS=$((ERRORS + 1))
else
    echo "  [OK] mkdocs build passed."
fi
echo ""

# ── Final result ──────────────────────────────────────────────────────────────
if [[ $ERRORS -ne 0 ]]; then
    echo "╔══════════════════════════════════════════════════════════════════╗"
    printf  "║  PUSH BLOCKED — %d check(s) failed. See above for details.     ║\n" "$ERRORS"
    echo "╚══════════════════════════════════════════════════════════════════╝"
    echo ""
    exit 1
fi

echo "╔══════════════════════════════════════════════════════════════════╗"
echo "║  All quality checks passed. Proceeding with push to main.       ║"
echo "╚══════════════════════════════════════════════════════════════════╝"
echo ""
exit 0
