{
  "name": "ai-agent-ui-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright E2E tests for ai-agent-ui",
  "scripts": {
    "test": "playwright test",
    "test:auth": "playwright test --project=auth-chromium",
    "test:frontend": "playwright test --project=frontend-chromium",
    "test:dashboard": "playwright test --project=dashboard-chromium",
    "test:admin": "playwright test --project=admin-chromium",
    "test:errors": "playwright test --project=errors-chromium",
    "report": "playwright show-report",
    "install-browsers": "playwright install chromium --with-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "typescript": "^5.7.0"
  }
}
