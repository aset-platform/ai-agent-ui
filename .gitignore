# Environment variables (contains API keys)
.env
.env.local
.env*.local

# Auto-generated docs — now committed (gen-files
# removed; regenerate manually if config changes)

# Node.js
node_modules/

# Python virtualenvs — covers any name
venv/
.venv/
demoenv/
env/
*env/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Next.js build output
.next/
out/
build/

# VS Code
.vscode/

# OS files
.DS_Store
Thumbs.db

# Screenshots (root-level only — keep frontend/public assets)
/*.png

# Logs
*.log
npm-debug.log*
yarn-debug.log*
logs/

# TypeScript build info
*.tsbuildinfo
next-env.d.ts

# Runtime data, charts, and Iceberg are now stored at ~/.ai-agent-ui/
# Keep these rules for backwards-compat if old project-local dirs remain.
data/raw/
data/processed/
data/forecasts/
data/cache/
data/metadata/*.json
charts/analysis/
charts/forecasts/
data/iceberg
data/iceberg/
data/avatars/
data/auth_deny_list.json

# MkDocs static build output
site/

# Iceberg catalog config (contains absolute local paths)
.pyiceberg.yaml

# Local Claude Code instructions (personal, not for repo)
instruction.txt

# MCP server config (contains API keys)
.mcp.json

# Serena — selective ignore (shared memories are tracked)
.serena/cache/
.serena/project.local.yml
.serena/memories/session/
.serena/memories/personal/

# Backend runtime data (deny-list, etc.)
backend/data/

# Lighthouse CI local artifacts
.lighthouseci/
